{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BeeOS",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#F5A623",
    "light": "#FFC66D",
    "dark": "#D4880B"
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://beeos.ai"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://beeos.ai/settings/api-keys"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "A2A Protocol",
            "pages": [
              "a2a/overview",
              "a2a/agent-cards",
              "a2a/json-rpc",
              "a2a/streaming",
              "a2a/rest-invoke"
            ]
          },
          {
            "group": "MCP",
            "pages": [
              "mcp/overview",
              "mcp/oauth",
              "mcp/tools",
              "mcp/resources"
            ]
          },
          {
            "group": "SDKs",
            "pages": ["sdks/typescript", "sdks/go"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/beeos-platform-v1.yaml"
      }
    ]
  },
  "api": {
    "baseUrl": "https://openapi.beeos.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "footerSocials": {
    "github": "https://github.com/beeos-ai",
    "x": "https://x.com/beeos_ai"
  }
}
